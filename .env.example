# Copy to `.env.local` for local development

# When set, API facades in src/api/services/* call the backend instead of localStorage stubs.
# Leave unset for frontend-only local work (see FRONTEND_DEV.md).
VITE_API_BASE_URL=https://api.example.com/v1

# Composio OAuth (CLE-19): after connecting in Profile → Integrations, the API redirects to
# /dashboard/profile?tab=integrations&connected=<provider> — ensure that URL is allowed in
# the Composio dashboard for your app (e.g. https://app.clearform.in).

# Set to false to require VITE_API_BASE_URL (no localStorage fallback in services).
VITE_USE_MOCK_API=true

# Firebase Auth (Microsoft redirect must start/finish on VITE_FIREBASE_AUTH_DOMAIN origin, e.g. app.clearform.in)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=app.clearform.in
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sentry — browser errors + tracing (optional locally; set in production deploy)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
