# Local development — copy this file to `.env.local` and fill Firebase from Firebase Console

VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_USE_MOCK_API=false

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Production API (Vercel — app.clearform.in)
# VITE_API_BASE_URL=https://api.clearform.in/api/v1

# Razorpay payment link (redirect checkout — no live API keys in app)
VITE_RAZORPAY_PAYMENT_LINK_URL=

# Set true only when Razorpay Checkout.js is wired with test/live keys
# VITE_ENABLE_RAZORPAY_CHECKOUT=false
