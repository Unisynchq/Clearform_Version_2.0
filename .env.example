# Copy to `.env.local` for local development
# Set all VITE_ variables in Vercel dashboard for production

# Backend API URL (no trailing slash)
VITE_API_BASE_URL=https://api.yourclearform.com/api/v1

# Set to false to use real backend
VITE_USE_MOCK_API=false

# Firebase — get from Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
